FROM alpine:3.20

ENV TZ=Asia/Shanghai

RUN mkdir -p usr/share/zoneinfo/Asia
COPY deploy/simpleDockerFile/etc/zoneinfo/Asia/Shanghai /usr/share/zoneinfo/Asia/Shanghai

WORKDIR /app
RUN mkdir etc
COPY deploy/simpleDockerFile/etc/gateway-api.yaml /app/etc/gateway-api.yaml
COPY deploy/simpleDockerFile/cmd/gateway /app/gateway

CMD ["./gateway", "-f", "etc/gateway-api.yaml"]
