FROM golang:alpine AS builder

LABEL stage=gobuilder

ENV CGO_ENABLED=0


RUN apk update --no-cache && apk add --no-cache tzdata

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download
COPY . .

RUN go build -ldflags="-s -w" -o /app/gateway app/gateway/gateway.go
RUN cp deploy/DockerFile/etc/gateway-api.yaml app/gateway/etc/gateway-api.yaml


FROM busybox:musl
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
COPY --from=builder /usr/share/zoneinfo/Asia/Shanghai /usr/share/zoneinfo/Asia/Shanghai
ENV TZ=Asia/Shanghai

WORKDIR /app
COPY --from=builder /app/gateway /app/gateway
COPY --from=builder /build/app/gateway/etc /app/etc

CMD ["./gateway", "-f", "etc/gateway-api.yaml"]
