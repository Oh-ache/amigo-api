FROM alpine:3.20

ENV TZ=Asia/Shanghai

RUN mkdir -p usr/share/zoneinfo/Asia
COPY deploy/simpleDockerFile/etc/zoneinfo/Asia/Shanghai /usr/share/zoneinfo/Asia/Shanghai

WORKDIR /app
RUN mkdir etc
COPY deploy/simpleDockerFile/etc/deviceRpc.yaml /app/etc/device.yaml
COPY deploy/simpleDockerFile/cmd/rpc/device /app/device

CMD ["./device", "-f", "etc/device.yaml"]
