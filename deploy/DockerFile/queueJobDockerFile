FROM alpine:3.20

ENV TZ=Asia/Shanghai

RUN mkdir -p usr/share/zoneinfo/Asia
COPY deploy/simpleDockerFile/etc/zoneinfo/Asia/Shanghai /usr/share/zoneinfo/Asia/Shanghai

WORKDIR /app
RUN mkdir etc
COPY deploy/simpleDockerFile/etc/queueJob.yaml /app/etc/queue.yaml
COPY deploy/simpleDockerFile/cmd/queue /app/queue

CMD ["./queue", "-f", "etc/queue.yaml"]
