FROM alpine:3.20

ENV TZ=Asia/Shanghai

RUN mkdir -p usr/share/zoneinfo/Asia
COPY deploy/simpleDockerFile/etc/zoneinfo/Asia/Shanghai /usr/share/zoneinfo/Asia/Shanghai

WORKDIR /app
RUN mkdir etc
COPY deploy/simpleDockerFile/etc/mqueueJob.yaml /app/etc/mqueue.yaml
COPY deploy/simpleDockerFile/cmd/mqueue /app/mqueue

CMD ["./mqueue", "-f", "etc/mqueue.yaml"]