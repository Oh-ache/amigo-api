syntax = "v1"

type Request {
	Name string `path:"name,options=you|me"`
}

CommonResp{
    Code int `json:"code"`
    Msg string `json:"msg"`
    Data interface{} `json:"data"`
}

EmptyResp{}

type Response {
	Message string `json:"message"`
}

service gateway-api {
	@handler GatewayHandler
	get /from/:name (Request) returns (Response)
}

